{
  "appId": "com.milfun.cocos",
  "productName": "MilFun",
  "copyright": "Copyright © MilFun",
  "electronDist": "node_modules/electron/dist",
  "directories": {
    "output": "dist"
  },
  "files": [
    "!app.js",
    "!license.js",
    "!collect.js",
    "!scripts/**/*",
    "!license-keys/**/*",
    "!src/**/*",
    "!src_processed/**/*",
    "!dist/**/*",
    "!README.md",
    "public.key",
    "loader-core.js",
    "app.jsc",
    "config.js",
    "license-service.js",
    "obfuscator-loader.js",
    "obfuscate-worker.js",
    "obfuscator-pool.js",
    "electron/**/*",
    "node_modules/**/*",
    "package.json"
  ],
  "asarUnpack": [
    "**/*.node",
    "node_modules/sharp/**/*",
    "node_modules/@img/**/*",
    "node_modules/bytenode/**/*",
    "obfuscate-worker.js",
    "obfuscator-loader.js",
    "obfuscator-pool.js",
    "electron/**/*"
  ],
  "extraResources": [
    {
      "from": "public.key",
      "to": "."
    },
    {
      "from": "milfun.config.example.json",
      "to": "milfun.config.example.json"
    }
  ],
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": ["x64"]
      }
    ]
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "MilFun"
  },
  "mac": {
    "target": ["dmg"],
    "category": "public.app-category.developer-tools"
  }
}
